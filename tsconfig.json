{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "exclude": [
    "src/interaction/feedbackTypes 2.ts",
    "src/interaction/taskProgressFeedback 2.ts",
    "src/interaction/useTaskInteractionFeedback 2.ts",
    "src/lib/mentor 2.ts",
    "src/lib/uiFeedback 2.ts",
    "src/rewards/rewardReducer 2.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
